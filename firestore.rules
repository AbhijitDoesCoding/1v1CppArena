rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == uid;
      // Elo stays admin-only; the owner may backfill their own email (used to
      // find players for private invites) but nothing else.
      allow update: if request.auth.uid == uid
        && request.resource.data.elo == resource.data.elo
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['email']);
    }
  }
}
